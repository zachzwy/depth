// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`SummaryView snapshots > five bullets, some with term highlights 1`] = `"<div class="view view--summary"><ul class="summary__list"><li class="summary__bullet" data-slot="0"><span class="summary__bar"></span><span class="summary__text">First <span class="term" data-slot="0" title="A thought.">idea</span> anchors the piece.</span></li><li class="summary__bullet" data-slot="1"><span class="summary__bar"></span><span class="summary__text">Second observation about <span class="term" data-slot="1" title="A measure.">depth</span>.</span></li><li class="summary__bullet" data-slot="2"><span class="summary__bar"></span><span class="summary__text">Third synthesis.</span></li><li class="summary__bullet" data-slot="3"><span class="summary__bar"></span><span class="summary__text">Fourth tension.</span></li><li class="summary__bullet" data-slot="4"><span class="summary__bar"></span><span class="summary__text">Fifth conclusion.</span></li></ul></div>"`;
