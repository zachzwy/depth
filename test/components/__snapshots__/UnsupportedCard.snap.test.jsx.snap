// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`UnsupportedCard snapshots > discussion variant (English) 1`] = `"<div class="state state--unsupported"><h2 class="state__title">This looks like a discussion thread</h2><p class="state__body">Depth currently summarizes the original post only; comments aren't supported yet.</p><div class="extraction-stats" aria-live="polite"><span class="extraction-stats__words">320 words</span><span class="extraction-stats__sep">·</span><span class="extraction-stats__kind extraction-stats__kind--discussion">discussion</span></div><button type="button" class="state__link">Try anyway</button></div>"`;

exports[`UnsupportedCard snapshots > feed variant (English) 1`] = `"<div class="state state--unsupported"><h2 class="state__title">This looks like a feed</h2><p class="state__body">Depth works best on individual articles — try opening a single post.</p><div class="extraction-stats" aria-live="polite"><span class="extraction-stats__kind extraction-stats__kind--feed">feed</span></div><button type="button" class="state__link">Try anyway</button></div>"`;

exports[`UnsupportedCard snapshots > feed variant (Simplified Chinese) 1`] = `"<div class="state state--unsupported"><h2 class="state__title">这看起来是一个信息流</h2><p class="state__body">Depth 更适合阅读单篇文章 —— 试着打开某一条具体的帖子。</p><div class="extraction-stats" aria-live="polite"><span class="extraction-stats__kind extraction-stats__kind--feed">信息流</span></div><button type="button" class="state__link">仍然尝试</button></div>"`;

exports[`UnsupportedCard snapshots > unsupported variant (English) 1`] = `"<div class="state state--unsupported"><h2 class="state__title">Couldn't find an article here</h2><p class="state__body">Depth works best on long-form writing.</p><div class="extraction-stats" aria-live="polite"><span class="extraction-stats__kind extraction-stats__kind--unsupported">no article found</span></div><button type="button" class="state__link">Try anyway</button></div>"`;
