// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`GlanceView snapshots > high confidence with no highlighted terms 1`] = `"<div class="view view--glance glance"><div class="glance__quote-mark" aria-hidden="true">“</div><p class="glance__one-sentence">A central claim about reading.</p><div class="glance__source-note"><span class="glance__source-left">SYNTHESIZED FROM THIS ARTICLE</span><span class="glance__conf is-high"><span class="glance__conf-dot"></span>HIGH CONFIDENCE</span></div></div>"`;

exports[`GlanceView snapshots > low confidence with two highlighted terms 1`] = `"<div class="view view--glance glance"><div class="glance__quote-mark" aria-hidden="true">“</div><p class="glance__one-sentence">Vary <span class="term" data-slot="1" title="How far the window moves.">stride</span> to shift the <span class="term" data-slot="0" title="Sliding-window combination.">convolution</span>.</p><div class="glance__source-note"><span class="glance__source-left">SYNTHESIZED FROM 1 SECTION</span><span class="glance__conf is-low"><span class="glance__conf-dot"></span>LOW CONFIDENCE</span></div></div>"`;

exports[`GlanceView snapshots > medium confidence with one highlighted term 1`] = `"<div class="view view--glance glance"><div class="glance__quote-mark" aria-hidden="true">“</div><p class="glance__one-sentence">The <span class="term" data-slot="0" title="Sliding-window combination.">convolution</span> sets the pace.</p><div class="glance__source-note"><span class="glance__source-left">SYNTHESIZED FROM 3 SECTIONS</span><span class="glance__conf is-medium"><span class="glance__conf-dot"></span>MEDIUM CONFIDENCE</span></div></div>"`;
