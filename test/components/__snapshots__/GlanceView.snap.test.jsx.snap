// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`GlanceView snapshots > high confidence with no highlighted terms 1`] = `"<div class="view view--glance"><blockquote class="glance__quote">A central claim about reading.</blockquote><div class="glance__meta"><span class="glance__termcount">NO KEY TERMS</span><span class="glance__confidence is-high"><span class="glance__confidence-dot"></span>HIGH CONFIDENCE</span></div></div>"`;

exports[`GlanceView snapshots > low confidence with two highlighted terms 1`] = `"<div class="view view--glance"><blockquote class="glance__quote">Vary <span class="term" data-slot="1" title="How far the window moves.">stride</span> to shift the <span class="term" data-slot="0" title="Sliding-window combination.">convolution</span>.</blockquote><div class="glance__meta"><span class="glance__termcount">2 / 2 TERMS</span><span class="glance__confidence is-low"><span class="glance__confidence-dot"></span>LOW CONFIDENCE</span></div></div>"`;

exports[`GlanceView snapshots > medium confidence with one highlighted term 1`] = `"<div class="view view--glance"><blockquote class="glance__quote">The <span class="term" data-slot="0" title="Sliding-window combination.">convolution</span> sets the pace.</blockquote><div class="glance__meta"><span class="glance__termcount">1 / 2 TERMS</span><span class="glance__confidence is-medium"><span class="glance__confidence-dot"></span>MEDIUM CONFIDENCE</span></div></div>"`;
